# Environment Variables for NebuBot Kiosk

# Chat Provider Configuration
# Options: 'demo' (default) or 'openai'
VITE_CHAT_PROVIDER=demo

# API Endpoint for OpenAI chat (only used when VITE_CHAT_PROVIDER=openai)
# This should point to your backend API that handles OpenAI calls
VITE_CHAT_API_ENDPOINT=http://localhost:3002/api/chat

# Backend API Base URL (optional - if not set, uses mock data)
VITE_API_BASE=http://localhost:3002

# ==================================================
# BACKEND CONFIGURATION (do NOT expose in frontend)
# ==================================================
# These variables should be set in your backend environment

# OpenAI API Key - NEVER expose this in the frontend!
# Set this in your backend/edge function environment
# OPENAI_API_KEY=sk-your-openai-api-key-here
